<!DOCTYPE html>
<html lang="{{ language }}">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ prompt | truncate(80) }} — BrouxAI</title>

  <!-- React + ReactDOM (requis par Recharts) -->
  <script crossorigin src="https://cdnjs.cloudflare.com/ajax/libs/react/18.2.0/umd/react.production.min.js"></script>
  <script crossorigin src="https://cdnjs.cloudflare.com/ajax/libs/react-dom/18.2.0/umd/react-dom.production.min.js"></script>

  <!-- Recharts UMD -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/recharts/2.12.0/Recharts.min.js"></script>

  <style>
    /* ── Variables CSS brand_kit ─────────────────────────────── */
    :root {
      --color-primary:  {{ colors.primary }};
      --color-positive: {{ colors.positive }};
      --color-negative: {{ colors.negative }};
      --color-bg:       #f8f9fa;
      --color-surface:  #ffffff;
      --color-text:     #1a1a1a;
      --color-muted:    #6b7280;
      --radius:         8px;
    }

    /* ── Reset & base ────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: system-ui, -apple-system, "Segoe UI", Helvetica, Arial, sans-serif;
      background: var(--color-bg);
      color: var(--color-text);
      line-height: 1.65;
      font-size: 16px;
    }

    /* ── Layout ──────────────────────────────────────────────── */
    .page-wrapper {
      max-width: 1200px;
      margin: 0 auto;
      padding: 2rem 1.5rem;
    }

    /* ── Header ──────────────────────────────────────────────── */
    .report-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding-bottom: 1.5rem;
      border-bottom: 3px solid var(--color-primary);
      margin-bottom: 2rem;
      gap: 1rem;
    }
    .report-header .brand {
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }
    .report-header .brand img {
      max-height: 48px;
      max-width: 160px;
      object-fit: contain;
    }
    .report-header .company-name {
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--color-primary);
    }
    .report-header .report-date {
      font-size: 0.875rem;
      color: var(--color-muted);
      white-space: nowrap;
    }

    /* ── Titre principal ─────────────────────────────────────── */
    .report-title {
      font-size: 1.75rem;
      font-weight: 800;
      color: var(--color-primary);
      margin-bottom: 0.5rem;
      line-height: 1.3;
    }
    .report-subtitle {
      font-size: 0.9rem;
      color: var(--color-muted);
      margin-bottom: 2rem;
    }

    /* ── Carte générique ─────────────────────────────────────── */
    .card {
      background: var(--color-surface);
      border-radius: var(--radius);
      padding: 1.5rem 1.75rem;
      margin-bottom: 1.75rem;
      box-shadow: 0 1px 4px rgba(0,0,0,.07);
    }
    .card-title {
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .08em;
      color: var(--color-muted);
      margin-bottom: 0.75rem;
    }

    /* ── Résumé exécutif ─────────────────────────────────────── */
    .executive-summary p {
      font-size: 1.05rem;
      font-weight: 500;
      line-height: 1.7;
    }

    /* ── Section graphiques ──────────────────────────────────── */
    .charts-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(480px, 1fr));
      gap: 1.5rem;
      margin-bottom: 1.75rem;
    }
    .chart-card {
      background: var(--color-surface);
      border-radius: var(--radius);
      padding: 1.25rem 1.5rem;
      box-shadow: 0 1px 4px rgba(0,0,0,.07);
    }
    .chart-title {
      font-size: 0.9rem;
      font-weight: 600;
      margin-bottom: 0.75rem;
      color: var(--color-text);
    }
    .chart-container {
      width: 100%;
      height: 280px;
    }

    /* ── Narration ───────────────────────────────────────────── */
    .narrative-section p {
      margin-bottom: 1rem;
      line-height: 1.8;
    }
    .narrative-section p:last-child { margin-bottom: 0; }

    /* ── Pied de page ────────────────────────────────────────── */
    .report-footer {
      margin-top: 3rem;
      padding-top: 1rem;
      border-top: 1px solid #e5e7eb;
      font-size: 0.8rem;
      color: var(--color-muted);
      text-align: center;
    }

    /* ── Impression ──────────────────────────────────────────── */
    @media print {
      body { background: white; font-size: 12pt; }
      .page-wrapper { max-width: 100%; padding: 0; }
      .card, .chart-card {
        box-shadow: none;
        border: 1px solid #e5e7eb;
        break-inside: avoid;
      }
      .charts-grid { grid-template-columns: 1fr 1fr; }
    }

    @media (max-width: 600px) {
      .charts-grid { grid-template-columns: 1fr; }
      .report-title { font-size: 1.35rem; }
    }
  </style>
</head>
<body>
  <div class="page-wrapper">

    <!-- ── En-tête ─────────────────────────────────────────── -->
    <header class="report-header">
      <div class="brand">
        {% if logo_url %}
        <img src="{{ logo_url }}" alt="Logo" />
        {% endif %}
        {% if company_name %}
        <span class="company-name">{{ company_name }}</span>
        {% endif %}
      </div>
      <span class="report-date">{{ report_date }}</span>
    </header>

    <!-- ── Titre ───────────────────────────────────────────── -->
    <h1 class="report-title">{{ prompt }}</h1>
    <p class="report-subtitle">Rapport #{{ report_id }}</p>

    <!-- ── Résumé exécutif ─────────────────────────────────── -->
    {% if paragraphs %}
    <div class="card executive-summary">
      <div class="card-title">Résumé exécutif</div>
      <p>{{ paragraphs[0] }}</p>
    </div>
    {% endif %}

    <!-- ── Graphiques ─────────────────────────────────────── -->
    {% if viz_specs %}
    <div class="charts-grid">
      {% for spec in viz_specs %}
      <div class="chart-card">
        <div class="chart-title">{{ spec.title }}</div>
        <div class="chart-container" id="chart-{{ loop.index0 }}"></div>
      </div>
      {% endfor %}
    </div>
    {% endif %}

    <!-- ── Narration complète ─────────────────────────────── -->
    <div class="card narrative-section">
      <div class="card-title">Analyse complète</div>
      {% for para in paragraphs %}
      <p>{{ para }}</p>
      {% endfor %}
    </div>

    <!-- ── Pied de page ────────────────────────────────────── -->
    <footer class="report-footer">
      Généré par BrouxAI &mdash; {{ report_id }} &mdash; {{ report_date }}
    </footer>

  </div><!-- /.page-wrapper -->

  <!-- ── Données viz injectées côté serveur ─────────────── -->
  <script>
    window.__VIZ_SPECS__ = {{ viz_specs_json }};
    window.__BRAND_COLORS__ = {
      primary:  "{{ colors.primary }}",
      positive: "{{ colors.positive }}",
      negative: "{{ colors.negative }}"
    };
  </script>

  <!-- ── Rendu Recharts ──────────────────────────────────── -->
  <script>
  (function () {
    if (typeof Recharts === "undefined" || typeof React === "undefined") {
      console.warn("BrouxAI: Recharts ou React non chargé — graphiques désactivés.");
      return;
    }

    var specs = window.__VIZ_SPECS__ || [];
    var colors = window.__BRAND_COLORS__;
    var R = Recharts;
    var h = React.createElement;

    var CHART_HEIGHT = 260;
    var CHART_MARGIN = { top: 10, right: 20, left: 0, bottom: 30 };

    function getChartColors(spec) {
      var c = (spec.colors || {});
      return {
        primary:  c.primary  || colors.primary  || "#1E3A8A",
        positive: c.positive || colors.positive || "#16A34A",
        negative: c.negative || colors.negative || "#DC2626",
      };
    }

    function getAggData(spec) {
      /* Les données sont embarquées dans la spec si disponibles,
         sinon on retourne un tableau vide (graphique vide gracieux). */
      return Array.isArray(spec.data) ? spec.data : [];
    }

    function renderBar(container, spec, data, c) {
      var chart = h(R.ResponsiveContainer, { width: "100%", height: CHART_HEIGHT },
        h(R.BarChart, { data: data, margin: CHART_MARGIN },
          h(R.CartesianGrid, { strokeDasharray: "3 3", stroke: "#f0f0f0" }),
          h(R.XAxis, { dataKey: spec.x, tick: { fontSize: 12 } }),
          h(R.YAxis, { tick: { fontSize: 12 } }),
          h(R.Tooltip, {}),
          h(R.Bar, { dataKey: spec.y, fill: c.primary, radius: [4,4,0,0] })
        )
      );
      ReactDOM.render(chart, container);
    }

    function renderLine(container, spec, data, c) {
      var chart = h(R.ResponsiveContainer, { width: "100%", height: CHART_HEIGHT },
        h(R.LineChart, { data: data, margin: CHART_MARGIN },
          h(R.CartesianGrid, { strokeDasharray: "3 3", stroke: "#f0f0f0" }),
          h(R.XAxis, { dataKey: spec.x, tick: { fontSize: 12 } }),
          h(R.YAxis, { tick: { fontSize: 12 } }),
          h(R.Tooltip, {}),
          h(R.Line, { type: "monotone", dataKey: spec.y, stroke: c.primary, strokeWidth: 2, dot: { r: 4 } })
        )
      );
      ReactDOM.render(chart, container);
    }

    function renderPie(container, spec, data, c) {
      var pieData = data.map(function(row) {
        return { name: row[spec.x] || row[spec.y], value: row[spec.y] || 0 };
      });
      var PIE_COLORS = [c.primary, c.positive, c.negative, "#8B5CF6", "#F59E0B"];
      var cells = pieData.map(function(_, i) {
        return h(R.Cell, { key: i, fill: PIE_COLORS[i % PIE_COLORS.length] });
      });
      var chart = h(R.ResponsiveContainer, { width: "100%", height: CHART_HEIGHT },
        h(R.PieChart, {},
          h(R.Pie, { data: pieData, dataKey: "value", nameKey: "name",
                     cx: "50%", cy: "50%", outerRadius: 100, label: true }, cells),
          h(R.Tooltip, {}),
          h(R.Legend, {})
        )
      );
      ReactDOM.render(chart, container);
    }

    function renderScatter(container, spec, data, c) {
      var chart = h(R.ResponsiveContainer, { width: "100%", height: CHART_HEIGHT },
        h(R.ScatterChart, { margin: CHART_MARGIN },
          h(R.CartesianGrid, { strokeDasharray: "3 3", stroke: "#f0f0f0" }),
          h(R.XAxis, { dataKey: spec.x, type: "number", name: spec.x, tick: { fontSize: 12 } }),
          h(R.YAxis, { dataKey: spec.y, type: "number", name: spec.y, tick: { fontSize: 12 } }),
          h(R.Tooltip, { cursor: { strokeDasharray: "3 3" } }),
          h(R.Scatter, { data: data, fill: c.primary })
        )
      );
      ReactDOM.render(chart, container);
    }

    function renderHistogram(container, spec, data, c) {
      /* Recharts n'a pas de type "histogram" natif — on utilise un BarChart */
      renderBar(container, spec, data, c);
    }

    var renderers = {
      bar:       renderBar,
      line:      renderLine,
      pie:       renderPie,
      scatter:   renderScatter,
      histogram: renderHistogram,
    };

    specs.forEach(function(spec, idx) {
      var container = document.getElementById("chart-" + idx);
      if (!container) return;
      var data = getAggData(spec);
      var c    = getChartColors(spec);
      var fn   = renderers[spec.chart_type] || renderBar;
      try {
        fn(container, spec, data, c);
      } catch (e) {
        container.innerHTML = "<p style='color:#6b7280;font-size:0.85rem;padding:1rem'>Graphique non disponible.</p>";
        console.error("BrouxAI chart error [" + idx + "]:", e);
      }
    });

  })();
  </script>

</body>
</html>
